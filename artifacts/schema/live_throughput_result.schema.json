{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cs4220-capstone.local/schema/live_throughput_result.schema.json",
  "title": "LiveThroughputResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input",
    "output_dir",
    "live_artifact_path",
    "chunk_duration_s",
    "wall_clock_ms",
    "wall_clock_ms_per_chunk",
    "throughput_chunks_per_second",
    "device_requested",
    "device_used",
    "source_mode",
    "status",
    "phase",
    "error_stage",
    "error_message",
    "stderr",
    "live_cli_exit_code",
    "live_runtime_status",
    "live_runtime_error_stage",
    "live_runtime_error_message",
    "timestamp",
    "metadata"
  ],
  "properties": {
    "input": {
      "type": "string",
      "minLength": 1
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "live_artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "chunk_duration_s": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 30.0
    },
    "wall_clock_ms": {
      "type": "number",
      "minimum": 0
    },
    "wall_clock_ms_per_chunk": {
      "type": "number",
      "minimum": 0
    },
    "throughput_chunks_per_second": {
      "type": "number",
      "minimum": 0
    },
    "device_requested": {
      "type": "string",
      "enum": ["cpu", "gpu"]
    },
    "device_used": {
      "type": "string",
      "enum": ["cpu", "gpu"]
    },
    "execution_kind": {
      "type": "string",
      "enum": ["cpu", "gpu_pytorch", "tensorrt"]
    },
    "source_mode": {
      "type": "string",
      "enum": ["mp3", "video-audio", "mic"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "error_stage": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "error_message": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "stderr": {
      "type": "string"
    },
    "live_cli_exit_code": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "live_runtime_status": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["ok", "error"]
        },
        {
          "type": "null"
        }
      ]
    },
    "live_runtime_error_stage": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "live_runtime_error_message": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clock_source",
        "live_timeout_s",
        "max_wall_clock_ms",
        "live_command",
        "device_requested",
        "device_used",
        "source_mode"
      ],
      "properties": {
        "clock_source": {
          "type": "string",
          "minLength": 1
        },
        "live_timeout_s": {
          "type": "number",
          "minimum": 0
        },
        "max_wall_clock_ms": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "live_command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "device_requested": {
          "type": "string",
          "enum": ["cpu", "gpu"]
        },
        "device_used": {
          "type": "string",
          "enum": ["cpu", "gpu"]
        },
        "source_mode": {
          "type": "string",
          "enum": ["mp3", "video-audio", "mic"]
        }
      }
    }
  }
}
